# Image to run in compose.prod.yml.
# Build it locally with:
#   docker login dhi.io
#   docker build -t transponder:local .
# If you need onion relays, build instead with:
#   docker build --build-arg CARGO_FEATURES='--features tor' -t transponder:tor .
TRANSPONDER_IMAGE=transponder:local

# Runtime files and paths
TRANSPONDER_CONFIG_FILE=./config/production.toml
TRANSPONDER_CREDENTIALS_DIR=./credentials
TRANSPONDER_SERVER_PRIVATE_KEY_SECRET_FILE=./secrets/server_private_key

# Published port on localhost
TRANSPONDER_PUBLISHED_PORT=8080

# Logging
TRANSPONDER_LOGGING_LEVEL=info

# Monitoring profile credentials
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=replace-with-a-long-random-password

# Public Grafana URL when using the proxy profile
GRAFANA_PUBLIC_HOST=grafana.example.com
GRAFANA_ROOT_URL=https://grafana.example.com

# ACME contact address for Caddy
CADDY_EMAIL=admin@example.com
